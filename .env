# ============================================================
# OpenSuite Environment Configuration
# ============================================================

# --- Domain & SSL ---
# Your domain name (must have DNS A record pointing to this server)
DOMAIN=opensuite.io

# Email for Let's Encrypt certificate registration (expiry notices)
CERTBOT_EMAIL=your-email@example.com

# Set to 1 for testing (uses Let's Encrypt staging server, no rate limits)
# Set to 0 for production (issues real certificates)
STAGING=1

# --- Site URL (used by frontend) ---
SITE_URL=https://opensuite.io

# --- Database ---
DB_PASSWORD=opensuite_secret

# --- Sentry Error Tracking ---
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
